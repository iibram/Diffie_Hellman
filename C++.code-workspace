{
	"folders": [
		{
			"path": "."
		}
	],
	"settings": {
		"editor.tabSize": 4
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "Build & Run Current File (CMD Pop-Up)",
				"type": "shell",
				"command": "cmd.exe",
				"args": [
					"/C",
					"cd /d \"${fileDirname}\" && g++ -std=c++20 -O2 *.cpp -o \"${fileBasenameNoExtension}.exe\" && start \"\" cmd /c \"\"${fileBasenameNoExtension}.exe\" ^& echo. ^& pause\""
				],
				"group": {
					"kind": "build",
					"isDefault": true
				},
				"problemMatcher": [
					"$gcc"
				],
				"presentation": {
					"echo": true,
					"reveal": "always",
					"focus": false,
					"panel": "shared",
					"showReuseMessage": true,
					"clear": false
				}
			},
			{
				"label": "Build Debug",
				"type": "shell",
				"command": "cmd.exe",
				"args": [
					"/C",
					"cd /d \"${fileDirname}\" && g++ -std=c++20 -g -O0 *.cpp -o \"${fileBasenameNoExtension}.exe\""
				],
				"group": "build",
				"problemMatcher": [
					"$gcc"
				]
			}
		]
	}
}